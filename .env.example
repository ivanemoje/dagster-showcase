# --- Service Connectivity ---
# Note: In docker-compose, use service names (redis, dagster). 
# For local dev, use localhost.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Port Configurations (Host Side) ---
# Binding to 127.0.0.1 for security
REDIS_PORT=6370
API_PORT_EXTERNAL=8080
FLOWER_PORT_EXTERNAL=5556
DAGSTER_PORT_EXTERNAL=3001

# --- Database Configuration ---
# Path to the DuckDB file (relative to project root or absolute)
DATABASE_PATH=./data/pipeline.duckdb

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# --- Dagster Configuration ---
DAGSTER_HOME=./dagster_home
DAGSTER_APP_NAME=dagster_sales_pipeline

# --- Data Contract ---
CONTRACT_PATH=./contracts/sales_pipeline_v1.json
SAMPLE_DATA_PATH=./example_data/sample_sales.csv

# --- Security (Placeholders for CI/CD or Production) ---
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=
SERVER_IP=
DEPLOYER_USER=
DEPLOYER_SSH=
FOLDER_PATH=
CR_PAT=ghp_your_github_pat_here
GITHUB_REPOSITORY=your_github_username/your_repository_name